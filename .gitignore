03-Quantum-Kernel-SVM-MNIST/results/final_validation/
03-Quantum-Kernel-SVM-MNIST/results/multi_seed/

# Compiled artifacts
*.npy.bak
*.log

# Grok / hidden tool dirs
**/.grok/
**/.test_tmp/

# Duplicate nested module (05 has an inner copy of itself)
05-Reinforcement-Learning-Noise-Mitigation/05-reinforcement-learning-noise-mitigation/
